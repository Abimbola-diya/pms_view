# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Jarvis Backend Configuration
JARVIS_PROVIDER=http
JARVIS_LLM_URL=https://cerebro-mj9g.onrender.com/
# Optional: comma-separated endpoint fallbacks.
# JARVIS_BACKEND_PATHS=/api/ask
# Optional timeout for backend call (milliseconds)
# JARVIS_BACKEND_TIMEOUT_MS=45000
# Optional: bearer token if your backend requires auth.
# JARVIS_API_KEY=your-backend-token

# Optional: Backend API Configuration
# NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional: Mapbox Configuration (for visualization)
# NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token
